Login Page : 
package pages;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;

import java.time.Duration;

public class LoginPage {

    WebDriver driver;
    WebDriverWait wait;

    By username = By.name("username");
    By password = By.name("password");
    By loginBtn = By.xpath("//button[@type='submit']");

    public LoginPage(WebDriver driver)
    {
        this.driver = driver;
        wait = new WebDriverWait(driver, Duration.ofSeconds(10));
    }

    public void enterUsername(String user)
    {
        wait.until(ExpectedConditions.visibilityOfElementLocated(username)).sendKeys(user);
    }

    public void enterPassword(String pass)
    {
        driver.findElement(password).sendKeys(pass);
    }

    public void clickLogin()
    {
        driver.findElement(loginBtn).click();
    }

    public void login(String user,String pass)
    {
        enterUsername(user);
        enterPassword(pass);
        clickLogin();
    }

}
Admin Page : 
package pages;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

import java.time.Duration;

public class AdminPage {

    WebDriver driver;
    WebDriverWait wait;

    public AdminPage(WebDriver driver) {
        this.driver = driver;
        wait = new WebDriverWait(driver, Duration.ofSeconds(10));
    }

    // Locators
    By adminMenu = By.xpath("//span[text()='Admin']");
    By usernameField = By.xpath("(//input[@class='oxd-input oxd-input--active'])[2]");
    By userRoleDropdown = By.xpath("(//div[contains(@class,'oxd-select-text')])[1]");
    By adminRole = By.xpath("//span[text()='Admin']");
    By searchBtn = By.xpath("//button[@type='submit']");
    By addBtn = By.xpath("//button[normalize-space()='Add']");
    By employeeName = By.xpath("//input[@placeholder='Type for hints...']");
    By empSuggestion = By.xpath("//div[@role='listbox']//span");
    By newUsername = By.xpath("(//input[@class='oxd-input oxd-input--active'])[3]");
    By passwordField = By.xpath("(//input[@type='password'])[1]");
    By confirmPasswordField = By.xpath("(//input[@type='password'])[2]");
    By saveBtn = By.xpath("//button[@type='submit']");
    By statusDropdown = By.xpath("(//div[contains(@class,'oxd-select-text')])[2]");
    By statusEnabled = By.xpath("//span[text()='Enabled']");

    By editBtn = By.xpath("(//button[@type='button'])[6]");
    By deleteBtn = By.xpath("(//button[@type='button'])[5]");
    By confirmDelete = By.xpath("//button[normalize-space()='Yes, Delete']");

    // Open Admin Page
    public void openAdmin() {
        wait.until(ExpectedConditions.elementToBeClickable(adminMenu)).click();
    }

    // Search User
    public void searchUser(String username){

        WebElement field = wait.until(
                ExpectedConditions.visibilityOfElementLocated(usernameField)
        );

        field.clear();
        field.sendKeys(username);

        wait.until(ExpectedConditions.elementToBeClickable(searchBtn)).click();
    }

    // Click Add
    public void clickAdd() {
        wait.until(ExpectedConditions.elementToBeClickable(addBtn)).click();
    }

    // Select Role
    public void selectUserRole() {
        wait.until(ExpectedConditions.elementToBeClickable(userRoleDropdown)).click();
        wait.until(ExpectedConditions.elementToBeClickable(adminRole)).click();
    }

    // Enter Employee Name
    public void enterEmployeeName(String empName) {

        WebElement empField = wait.until(
                ExpectedConditions.visibilityOfElementLocated(employeeName)
        );

        empField.clear();
        empField.sendKeys(empName);

        WebElement suggestion = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//div[@role='listbox']//span")
                )
        );

        suggestion.click();
    }

    // Select Status
    public void selectStatus(){

        wait.until(ExpectedConditions.elementToBeClickable(statusDropdown)).click();

        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.xpath("//div[@role='listbox']//span[text()='Enabled']")
        )).click();
    }

    // Enter Username
    public void enterUsername(String username) {
        wait.until(ExpectedConditions.visibilityOfElementLocated(newUsername)).sendKeys(username);
    }

    // Enter Password
    public void enterPassword(String password){

        WebElement pass = wait.until(
                ExpectedConditions.visibilityOfElementLocated(passwordField)
        );

        pass.clear();
        pass.sendKeys(password);
    }

    // Confirm Password
    public void confirmPassword(String password) {
        wait.until(ExpectedConditions.visibilityOfElementLocated(confirmPasswordField)).sendKeys(password);
    }

    // Click Save
    public void clickSave() {
        wait.until(ExpectedConditions.elementToBeClickable(saveBtn)).click();
    }

    // Add User Method
    public void addUser(String empName, String username, String password){

        clickAdd();
        selectUserRole();
        enterEmployeeName(empName);
        selectStatus();
        enterUsername(username);
        enterPassword(password);
        confirmPassword(password);
        clickSave();
    }
    // Edit User
    public void editUser(String newName) {

        wait.until(ExpectedConditions.elementToBeClickable(editBtn)).click();

        WebElement field = wait.until(
                ExpectedConditions.visibilityOfElementLocated(usernameField)
        );

        field.clear();
        field.sendKeys(newName);

        wait.until(ExpectedConditions.elementToBeClickable(saveBtn)).click();
    }

    // Delete User
    public void deleteUser() {

        WebElement checkbox = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.xpath("(//div[@class='oxd-checkbox-wrapper']//span)[1]")
                )
        );

        checkbox.click();

        wait.until(ExpectedConditions.elementToBeClickable(deleteBtn)).click();

        wait.until(ExpectedConditions.elementToBeClickable(confirmDelete)).click();
    }
}
