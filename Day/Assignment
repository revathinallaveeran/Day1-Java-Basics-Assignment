//3. Write a basic selenium + testNG program to open a browser and navigate to website. Make assertion like the website landed properly or not
Answer : 
package tests;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.Assert;
import org.testng.annotations.AfterMethod;
import org.testng.annotations.BeforeMethod;
import org.testng.annotations.Test;

public class Browseropen {

    WebDriver driver;

    @BeforeMethod
    public void setup() {
        driver = new ChromeDriver();
        driver.manage().window().maximize();
    }

    @Test
    public void openWebsiteTest() {
        driver.get("https://www.google.com");

        String actualTitle = driver.getTitle();
        String expectedTitle = "Google";

        Assert.assertEquals(actualTitle, expectedTitle, "Title mismatch!");
    }

    @AfterMethod
    public void teardown() {
        driver.quit();
    }
}

//4. Write a data driven test using dataproviders when u have to give different site urls and navigate to that sites based on the data
Answer : 
package tests;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.annotations.DataProvider;
import org.testng.annotations.Test;

public class dataprovider {

    @DataProvider(name = "websiteData")
    public Object[][] getData() {
        return new Object[][] {
            {"https://www.google.com"},
            {"https://www.facebook.com"},
            {"https://www.amazon.in"}
        };
    }

    @Test(dataProvider = "websiteData")
    public void openWebsites(String url) {
        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();

        driver.get(url);
        System.out.println("Opened: " + url);

        driver.quit();
    }
}

